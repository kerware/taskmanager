# ── Fichier modèle — NE PAS COMMITTER le fichier .env réel ───────────────────
# Copiez ce fichier en .env et remplissez les valeurs

# Backend — Profil Spring (laisser vide pour H2 en dev)
SPRING_PROFILES_ACTIVE=

# Backend — PostgreSQL (seulement si SPRING_PROFILES_ACTIVE=prod)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/taskmanager
SPRING_DATASOURCE_USERNAME=app
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# Frontend — URL de l'API (laisser vide pour utiliser le proxy Vite en dev)
VITE_API_URL=
